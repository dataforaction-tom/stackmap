{
  "name": "stackmap",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight architecture mapping for social purpose organisations",
  "scripts": {
    "dev": "next dev",
    "build": "next build && python -m mkdocs build -d out/docs",
    "build:app": "next build",
    "build:docs": "python -m mkdocs build -d out/docs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.27",
    "mermaid": "^11.13.0",
    "next": "^14.2.35",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "happy-dom": "^20.8.9",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.2"
  }
}
